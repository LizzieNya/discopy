# Your Discord Bot Token (for the bot)
# Get one from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your Discord User Token (for the CLI tool and bot fallback)
# This lets the bot download from any channel YOU can access when the bot is not in the server
# To get your token: Open Discord in browser > F12 > Console > type: 
#   (webpackChunkdiscord_app.push([[''],{},e=>{m=[];for(let c in e.c)m.push(e.c[c])}]),m).find(m=>m?.exports?.default?.getToken!==void 0).exports.default.getToken()
DISCORD_USER_TOKEN=your_user_token_here

# Zip Download Server Configuration
# Set the port for the local web server to host ZIP files
PORT=3000

# Set the public URL if you are hosting this on a VPS like Oracle Cloud
# Example: http://123.45.67.89:3000
PUBLIC_URL=http://localhost:3000
